{
  "manifest_version": 3,
  "name": "AliExpress Invoice Downloader",
  "description": "Download official invoices for your AliExpress orders.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.aliexpress.com/*",
    "*://gateway.aliexpress.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "offscreen_documents": {
    "documents": ["offscreen/offscreen.html"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.aliexpress.com/*"],
      "js": ["content/order-page.js"],
      "run_at": "document_idle"
    }
  ]
}